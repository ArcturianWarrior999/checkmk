set -e

cd -- "${BASH_SOURCE%/*}"

# 1. Build
bazel build //packages/mk-oracle:mk-oracle

# 2. Download and unpack Oracle instant client
bazel build //omd/packages/oci:oci_light_lin_x64
runtime_dir="${PWD}/runtimes/plugins/packages/mk-oracle"
mkdir -p "${runtime_dir}"
unzip -uoq "$(bazel info bazel-bin)/omd/packages/oci/oci_light_lin_x64.zip" -d "${runtime_dir}"
libaio=$(ldconfig -p | grep libaio.so.1 | awk '{print $NF}')
if [ -e "${libaio}" ]; then
    ln -sf "${libaio}" "${runtime_dir}/libaio.so.1"
else
    echo "libaio absent" >&2
    exit 1
fi

# 3. Run mk-oracle and check output
binary="$(bazel info bazel-bin)/packages/mk-oracle/mk-oracle"
output=$(MK_LIBDIR=./runtimes "${binary}" -c tests/files/test-mini-one-section.yml 2>&1 || true)
line_count=$(echo "${output}" | wc -l)
echo "${output}"
echo "---"
echo "Lines: ${line_count}"
if [ "${line_count}" -lt 3 ]; then
    echo "FAIL: expected good output, got ${line_count}" >&2
    exit 1
fi
echo "OK: non-root can exec non-root code"

# 4. Run mk-oracle as root — expect empty output (no permissions to read config)
sudo_output=$(sudo MK_LIBDIR=./runtimes "${binary}" -c tests/files/test-mini-one-section.yml 2>&1 || true)
if [ -n "${sudo_output}" ]; then
    echo "FAIL: expected empty output from sudo run, got:" >&2
    echo "${sudo_output}" >&2
    exit 1
fi
echo "OK: root can't exec non-root code"

# 5. Create the custom-metric SQL file and run as non-root — expect it is read and executed
sql_output=$(MK_LIBDIR=./runtimes "${binary}" -c tests/files/test-custom-metric.yml 2>&1 || true)
echo "${sql_output}"
echo "---"
if ! echo "${sql_output}" | grep -q "details:hello"; then
    echo "FAIL: expected custom SQL file output 'details:hello', got:" >&2
    echo "${sql_output}" >&2
    exit 1
fi
echo "OK: non-root reads and executes custom SQL file"

# 6. Run the custom-metric config as root — expect empty output (no permissions to read the runtime)
sudo_sql_output=$(sudo MK_LIBDIR=./runtimes "${binary}" -c tests/files/test-custom-metric.yml 2>&1 || true)
if [ -n "${sudo_sql_output}" ]; then
    echo "FAIL: expected empty output from sudo run with custom SQL file, got:" >&2
    echo "${sudo_sql_output}" >&2
    exit 1
fi
echo "OK: root can't read non-root custom SQL file"
