# ora_local: a local Oracle on localhost. This is what the Docker tier runs
# (Oracle Database 23ai Free, SID FREE) but is not Docker-specific: on Windows
# there is no Docker, yet a directly-installed local Oracle Free may be present.
ora_local =
 (DESCRIPTION =
 (ADDRESS_LIST =
 (ADDRESS = (PROTOCOL = TCP)(HOST = localhost)(PORT = 1521))
 )
 (CONNECT_DATA =
 (SID = FREE)
 (SERVER = DEDICATED)
 )
 )


ora_remote =
  (DESCRIPTION =
  (ADDRESS_LIST =
  (ADDRESS = (PROTOCOL = TCP)(HOST =  oracle-rocky-ci.lan.checkmk.net)(PORT = 1521))
  )
  (CONNECT_DATA =
  (SID = SID23)
  (SERVER = DEDICATED)
  )
  )

